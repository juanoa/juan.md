{
  "name": "converter",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier . --write --config ../../prettier.config.mjs --ignore-path ../../.prettierignore",
    "format:check": "pnpm exec prettier . --check --config ../../prettier.config.mjs --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@juan/ui": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@tailwindcss/vite": "^4.2.2",
    "vite-plugin-static-copy": "^2.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
