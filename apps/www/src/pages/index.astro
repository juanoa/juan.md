---
import {
  ItemDescription,
  ItemContent,
  ItemTitle,
  Item,
  ItemMedia,
} from "@juan/ui/components/ui/item";
import LogList from "@/components/logs/LogList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CollocationsLogo } from "@/components/projects/CollocationsLogo";
import { OnePointZeroOneLogo } from "@/components/projects/OnePointZeroOneLogo";
import { MitoHoverCard } from "@/components/index/hover-cards/MitoHoverCard";
import { InditexHoverCard } from "@/components/index/hover-cards/InditexHoverCard";
import GitHubWeeklyContributions from "@/components/index/GitHubWeeklyContributions.astro";

const pageTitle = "Juan Otálora";
---

<BaseLayout pageTitle={pageTitle} isHomePage={true}>
  <article class="prose prose-sm dark:prose-invert">
    <section>
      <h2>Work</h2>
      <p>
        I work on the founding team at <MitoHoverCard
          text="MITO"
          client:load
        />, designing and building interfaces for our first customers next to
        amazing people like Danny Saltaren, Dani Latorre, Nacho González and
        Keyvan Akbari.
      </p>
      <p>
        I previously worked at <InditexHoverCard text="Inditex" client:load /> (zara.com)
        crafting the interfaces of the product and catalog management tool for all
        the e-commerces in the company.
      </p>
      <h2>A man on a mission</h2>
      <p>
        I’ve always trusted technology, not just as a tool, but as an extension
        of human intent. Some learned to fear it. I chose to believe in it.
      </p>
      <p>
        Technology reflects who we are. In the right hands, it gives people
        agency, clarity, and the power to shape their lives.
      </p>
      <p>
        What would it take to reclaim the web as a space for creativity,
        intimacy and intellectualism?
      </p>
      <GitHubWeeklyContributions />
    </section>

    <section>
      <h2>Projects</h2>
      <div class="not-prose mt-6">
        <a href="https://www.onepointzeroone.dev/">
          <Item variant="outline">
            <ItemMedia variant="image">
              <OnePointZeroOneLogo />
            </ItemMedia>
            <ItemContent>
              <ItemTitle>1.01^n</ItemTitle>
              <ItemDescription>
                An almanack of evergreen content for SWE
              </ItemDescription>
            </ItemContent>
          </Item>
        </a>
      </div>
      <div class="not-prose mt-3">
        <a href="https://collocations.juan.md">
          <Item variant="outline">
            <ItemMedia variant="image">
              <CollocationsLogo />
            </ItemMedia>
            <ItemContent>
              <ItemTitle>Collocations</ItemTitle>
              <ItemDescription>
                A search engine for English collocations
              </ItemDescription>
            </ItemContent>
          </Item>
        </a>
      </div>
    </section>

    <section class="mt-10">
      <h2>Logs</h2>
      <LogList />
    </section>

    <section class="mt-10">
      <hr />

      <p>
        <a href="https://x.com/juanoa_">X</a> / <a
          href="https://linkedin.com/in/juanoa">LinkedIn</a
        >
      </p>
    </section>
  </article>
</BaseLayout>
