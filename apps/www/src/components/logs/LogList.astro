---
import { getCollection } from "astro:content";

const isProduction = import.meta.env.PROD;
const logDateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  year: "numeric",
  timeZone: "UTC",
});

function formatLogDate(date: Date) {
  return logDateFormatter.format(date);
}

const logs = (
  await getCollection(
    "logs",
    (entry) => !entry.id.includes("/") && (!isProduction || !entry.data.draft),
  )
).sort((left, right) => {
  const createdAtDifference =
    right.data.createdAt.getTime() - left.data.createdAt.getTime();

  if (createdAtDifference !== 0) {
    return createdAtDifference;
  }

  return left.data.title.localeCompare(right.data.title);
});
---

<ul class="not-prose mt-6 space-y-4">
  {
    logs.map((log) => (
      <li>
        <a href={`/${log.id}`} class="group block">
          <div class="flex flex-col gap-1 text-sm sm:grid sm:grid-cols-[minmax(0,1fr)_auto] sm:items-baseline sm:gap-x-2">
            <div class="flex min-w-0 items-baseline gap-1">
              <span class="min-w-0 truncate font-medium hover:underline">
                {log.data.title}
              </span>
              <span
                aria-hidden="true"
                class="hidden min-w-0 flex-1 border-b-2 border-dotted transition-all sm:block"
              />
            </div>
            <time
              datetime={log.data.createdAt.toISOString().split("T")[0]}
              data-log-date
              class="text-muted-foreground group-hover:text-foreground shrink-0 text-xs font-normal transition-all sm:text-sm">
              {formatLogDate(log.data.createdAt)}
            </time>
          </div>
        </a>
      </li>
    ))
  }
</ul>

<script>
  const logDateFormatter = new Intl.DateTimeFormat(undefined, {
    month: "short",
    year: "numeric",
    timeZone: "UTC",
  });

  document
    .querySelectorAll<HTMLTimeElement>("time[data-log-date]")
    .forEach((time) => {
      const date = new Date(`${time.dateTime}T00:00:00.000Z`);

      if (!Number.isNaN(date.valueOf())) {
        time.textContent = logDateFormatter.format(date);
      }
    });
</script>
