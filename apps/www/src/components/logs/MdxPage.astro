---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buttonVariants } from "@juan/ui/components/ui/button";
import {
  getAlternateLogLinks,
  getLogHref,
  getLogLocale,
  getTranslationCta,
} from "@/lib/logs";

interface Props {
  title: string;
  entryId: string;
  translations?: CollectionEntry<"logs">[];
}

const { title, entryId, translations = [] } = Astro.props;
const locale = getLogLocale(entryId);
const alternateLinks = getAlternateLogLinks(entryId, translations);
---

<BaseLayout pageTitle={title} htmlLang={locale}>
  {
    alternateLinks.map(({ locale: alternateLocale, href }) => (
      <link
        slot="head"
        rel="alternate"
        hreflang={alternateLocale}
        href={new URL(href, Astro.site).toString()}
      />
    ))
  }
  <article class="prose prose-sm dark:prose-invert">
    <h1>{title}</h1>
    {
      translations.map((translation) => (
        <a href={getLogHref(translation.id)}>
          {getTranslationCta(getLogLocale(translation.id))}
        </a>
      ))
    }
    <slot />
  </article>
</BaseLayout>
