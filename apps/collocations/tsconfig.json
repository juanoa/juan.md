{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*", "../../packages/ui/src/**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@juan/ui": ["../../packages/ui/src/index"],
      "@juan/ui/*": ["../../packages/ui/src/*"]
    },
    "types": ["astro/client", "react", "react-dom"]
  }
}
