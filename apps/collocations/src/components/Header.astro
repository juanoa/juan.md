---
import { CollocationsSearchBar } from "src/components/CollocationsSearchBar";

interface Props {
  showSearchBar?: boolean;
}

const { showSearchBar = true } = Astro.props;

if (!showSearchBar) {
  return null;
}
---

<header class="mx-auto flex w-full max-w-xl justify-center p-6">
  <CollocationsSearchBar client:load />
</header>
