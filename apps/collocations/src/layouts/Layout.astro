---
import "@juan/ui/styles.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "English Collocations",
  description = "Learn English collocations with shared UI components and styles.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
