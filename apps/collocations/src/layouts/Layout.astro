---
import "@juan/ui/styles.css";
import Header from "src/components/Header.astro";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  showSearchBar?: boolean;
}

const {
  title = "English Collocations",
  description = "Learn English collocations with shared UI components and styles.",
  showSearchBar = true,
} = Astro.props;

const site = Astro.site ?? new URL("https://collocations.juan.md");
const canonicalUrl = new URL(Astro.url.pathname, site);
const socialImageUrl = new URL("/og.webp", site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      (() => {
        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
        const applySystemTheme = () => {
          document.documentElement.classList.toggle("dark", mediaQuery.matches);
        };

        window.localStorage.removeItem("theme");
        applySystemTheme();
        mediaQuery.addEventListener("change", applySystemTheme);
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="English Collocations" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta
      property="og:image:alt"
      content="English Collocations social preview image"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta
      name="twitter:image:alt"
      content="English Collocations social preview image"
    />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header showSearchBar={showSearchBar} />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="text-muted-foreground px-4 py-6 text-center text-xs">
      <a
        href="/about"
        class="text-foreground font-medium underline underline-offset-4"
        >About</a
      >
      <span class="text-muted-foreground/70 mx-1">·</span>
      <a
        href="/privacy"
        class="text-foreground font-medium underline underline-offset-4"
        >Privacy</a
      >
      <span class="text-muted-foreground/70 mx-1">·</span>
      Built by
      <a
        href="https://juan.md"
        class="text-foreground font-medium underline underline-offset-4">Juan</a
      >
    </footer>
    <Analytics />
  </body>
</html>
