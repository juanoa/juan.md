{
  "name": "app",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "routes:generate": "tsr generate",
    "build": "tsr generate && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier . --write --config ../../prettier.config.mjs --ignore-path ../../.prettierignore",
    "format:check": "pnpm exec prettier . --check --config ../../prettier.config.mjs --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@juan/ui": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "hls.js": "^1.6.16",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "3.8.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
