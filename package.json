{
  "name": "juan-md",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "turbo build",
    "build:www": "turbo build --filter=www",
    "build:collocations": "turbo build --filter=collocations",
    "preview": "turbo preview",
    "preview:www": "turbo preview --filter=www",
    "preview:collocations": "turbo preview --filter=collocations",
    "dev": "turbo dev",
    "dev:www": "turbo dev --filter=www",
    "dev:collocations": "turbo dev --filter=collocations",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "ui:add": "shadcn add --cwd apps/www",
    "ui:add:collocations": "shadcn add --cwd apps/collocations"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "0.7.1",
    "shadcn": "^3.8.5",
    "turbo": "^2.5.8",
    "typescript-eslint": "^8.57.1"
  }
}
